PORT=5000
# Required (non-empty): DB_HOST, DB_USER, DB_NAME, JWT_SECRET — the server exits with a clear hint if any are missing.
DB_HOST=localhost
DB_USER=root
# Optional: leave empty only if your MySQL user has no password.
DB_PASSWORD=admin
DB_NAME=team_tasks
JWT_SECRET=your_jwt_secret
# Optional: comma-separated frontend URLs for CORS (e.g. https://your-app.vercel.app,http://localhost:5173)
FRONTEND_URL=http://localhost:5173
